# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/medirx
MONGODB_URI=mongodb://localhost:27017/medirx

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Paste the entire JSON content of your Firebase service account key
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID",...}

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# DO NOT expose this key to the frontend — backend proxy only
GEMINI_API_KEY=AIzaSyCW2Ie3ioVYoRqeHEc4jA1mv5Nb4aZLWD4
GEMINI_MODEL=gemini-1.5-flash

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
